// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  VISUALIZADOR
  EDUCADOR
}

enum AtividadeEnum {
  REFORCO_ESCOLAR
  PROGRAMA_60MAIS
  FUTEBOL
  QUENTINHAS
  OUTRO
}

enum Turno {
  MANHA
  TARDE
  NOITE
}

model Turma {
  id         String        @id @default(uuid()) @db.Uuid
  nome       String        @db.VarChar(100)
  atividade  AtividadeEnum
  turno      Turno?
  educadorId String?       @db.Uuid // Corrigido (Check)
  educador   Usuario?      @relation(fields: [educadorId], references: [id])

  ativa    Boolean  @default(true)
  criadoEm DateTime @default(now())
}

model Usuario {
  id           String        @id @default(uuid()) @db.Uuid // Corrigido (Check)
  nome         String
  senha        String
  email        String        @unique
  dataCriacao  DateTime      @default(now())
  role         Role          @default(VISUALIZADOR)
  estaAtivado  Boolean       @default(true)
  atendimentos Atendimento[]
  pessoas      Pessoa[]
  turmas       Turma[]
}

model Pessoa {
  id             String   @id @default(uuid()) @db.Uuid
  nomeCompleto   String   @db.VarChar(200)
  cpf            String?  @unique @db.VarChar(14)
  dataNascimento DateTime @db.Date
  telefone       String?  @db.VarChar(20)

  tipo TipoPessoa
  sexo Sexo?

  nomeResponsavel     String? @db.VarChar(200)
  telefoneResponsavel String? @db.VarChar(20)

  observacoes String? @db.Text

  ativo Boolean @default(true)

  // ERRO AQUI: registradoPor deve ser @db.Uuid para ligar com Usuario.id
  registradoPor String  @db.Uuid
  usuario       Usuario @relation(fields: [registradoPor], references: [id])

  dataCriacao  DateTime      @default(now())
  atualizadoEm DateTime      @updatedAt
  atendimentos Atendimento[]
}

model Atendimento {
  id              String        @id @default(uuid()) @db.Uuid // Adicionado @db.Uuid
  pessoaId        String?       @db.Uuid
  pessoa          Pessoa?       @relation(fields: [pessoaId], references: [id])
  turmaId         String?       @db.Uuid // Recomendado usar UUID aqui também
  atividade       AtividadeEnum
  dataAtendimento DateTime
  presente        Boolean
  observacao      String

  // ERRO AQUI: registradoPor deve ser @db.Uuid para ligar com Usuario.id
  registradoPor String  @db.Uuid
  usuario       Usuario @relation(fields: [registradoPor], references: [id])

  dataCriacao DateTime @default(now())
}

enum TipoPessoa {
  BENEFICIARIO
  VOLUNTARIO
}

enum Sexo {
  M
  F
  OUTRO
}
